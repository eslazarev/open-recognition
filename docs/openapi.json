{
  "openapi": "3.1.0",
  "info": {
    "title": "open-recognition",
    "version": "0.1.0",
    "description": "Self-hosted, **boto3-compatible** drop-in for the AWS Rekognition Faces API.\n\nThe native protocol is **AWS JSON-1.1**: every call is `POST /` with an\n`X-Amz-Target: RekognitionService.<Action>` header and a JSON body. Point\n`boto3.client(\"rekognition\", endpoint_url=...)` at the server and your\nexisting code works unchanged.\n\nFor exploration this document also exposes each action as `POST /<Action>`\n(e.g. `POST /DetectFaces`), which the server accepts as an alias \u2014 that is\nwhat the **Try it out** button uses. Both forms hit the same handlers.\n\nErrors follow AWS: HTTP 4xx/5xx with `{\"__type\": \"...\", \"Message\": \"...\"}`\nand an `x-amzn-errortype` header.\n",
    "license": {
      "name": "MIT"
    }
  },
  "tags": [
    {
      "name": "Faces",
      "description": "AWS Rekognition Faces API operations."
    }
  ],
  "paths": {
    "/DetectFaces": {
      "post": {
        "operationId": "DetectFaces",
        "tags": [
          "Faces"
        ],
        "summary": "Detect faces in an image \u2014 bounding boxes, confidence, and landmarks.",
        "description": "AWS JSON-1.1 action **DetectFaces**. Canonical call: `POST /` with header `X-Amz-Target: RekognitionService.DetectFaces`.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-amz-json-1.1": {
              "schema": {
                "$ref": "#/components/schemas/DetectFacesRequest"
              }
            },
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DetectFacesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/x-amz-json-1.1": {
                "schema": {
                  "$ref": "#/components/schemas/DetectFacesResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DetectFacesResponse"
                }
              }
            }
          },
          "400": {
            "description": "AWS error (InvalidParameterException, ResourceNotFoundException, \u2026)",
            "content": {
              "application/x-amz-json-1.1": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
